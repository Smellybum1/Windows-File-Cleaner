<Window x:Class="WindowsFileCleaner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Windows File Cleaner"
        Height="760"
        Width="1180"
        MinHeight="640"
        MinWidth="980"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="6,0,0,0" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#16202A" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Storage Scan"
                           FontSize="26"
                           FontWeight="SemiBold" />
                <TextBlock Text="Read-only review of cleanup candidates"
                           Foreground="#526171"
                           Margin="0,3,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="ScopePathBox"
                             Width="420"
                             Height="34"
                             VerticalContentAlignment="Center"
                             Text="C:\Users\moxhe"
                             TextChanged="ScopePathBox_TextChanged" />
                    <Button x:Name="BrowseScopeButton"
                            Content="Browse..."
                            MinWidth="100"
                            Click="BrowseScopeButton_Click" />
                    <Button x:Name="ScanButton"
                            Content="Scan"
                            Click="ScanButton_Click" />
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            IsEnabled="False"
                            Click="CancelButton_Click" />
                </StackPanel>
                <TextBlock x:Name="ScopeSafetyNoteText"
                           Foreground="#526171"
                           Margin="0,6,0,0"
                           Width="680"
                           TextWrapping="Wrap" />
                <CheckBox x:Name="RealProfilePreflightCheckBox"
                          Content="I ran MVP preflight and fixture review before scanning this real profile."
                          Margin="0,8,0,0"
                          Visibility="Collapsed"
                          Checked="RealProfilePreflightCheckBox_Changed"
                          Unchecked="RealProfilePreflightCheckBox_Changed" />
                <TextBlock x:Name="ScanGateText"
                           Foreground="#526171"
                           Margin="0,4,0,0"
                           Width="680"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1"
                     Columns="4"
                     Margin="0,0,0,12">
            <Border Background="White" BorderBrush="#DCE3EA" BorderThickness="1" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total size" Foreground="#526171" />
                    <TextBlock x:Name="TotalSizeText" Text="-" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#DCE3EA" BorderThickness="1" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Folders" Foreground="#526171" />
                    <TextBlock x:Name="FolderCountText" Text="-" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#DCE3EA" BorderThickness="1" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Files" Foreground="#526171" />
                    <TextBlock x:Name="FileCountText" Text="-" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#DCE3EA" BorderThickness="1" Padding="14">
                <StackPanel>
                    <TextBlock Text="Access issues" Foreground="#526171" />
                    <TextBlock x:Name="AccessIssueCountText" Text="-" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#DCE3EA"
                BorderThickness="1"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="ReviewMixText"
                           Text="Review mix appears after a scan."
                           Foreground="#526171"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="SafetySummaryText"
                           Text="Safety summary appears after a scan."
                           Foreground="#526171"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap" />
                <WrapPanel Margin="0,8,0,0">
                    <Button x:Name="SafetyHighRiskButton"
                            Content="Review high risk"
                            MinWidth="125"
                            IsEnabled="False"
                            Click="SafetyHighRiskButton_Click" />
                    <Button x:Name="SafetyProtectedButton"
                            Content="Review protected"
                            MinWidth="135"
                            IsEnabled="False"
                            Click="SafetyProtectedButton_Click" />
                    <Button x:Name="SafetyAccessIssuesButton"
                            Content="Review access"
                            MinWidth="120"
                            IsEnabled="False"
                            Click="SafetyAccessIssuesButton_Click" />
                    <Button x:Name="SafetyReparsePointsButton"
                            Content="Review reparse"
                            MinWidth="125"
                            IsEnabled="False"
                            Click="SafetyReparsePointsButton_Click" />
                    <Button x:Name="SafetyQuarantineCandidatesButton"
                            Content="Review quarantine"
                            MinWidth="145"
                            IsEnabled="False"
                            Click="SafetyQuarantineCandidatesButton_Click" />
                    <Button x:Name="SafetyNoCategoryButton"
                            Content="Review no category"
                            MinWidth="145"
                            IsEnabled="False"
                            Click="SafetyNoCategoryButton_Click" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.ColumnSpan="3" Margin="0,0,0,10">
                <WrapPanel x:Name="ReviewFilterToolbar">
                    <Button x:Name="AllFilterButton"
                            Content="All"
                            Click="AllFilterButton_Click" />
                    <Button x:Name="LikelySafeFilterButton"
                            Content="Likely safe"
                            Click="LikelySafeFilterButton_Click" />
                    <Button x:Name="CautionFilterButton"
                            Content="Caution"
                            Click="CautionFilterButton_Click" />
                    <Button x:Name="HighRiskFilterButton"
                            Content="High risk"
                            Click="HighRiskFilterButton_Click" />
                    <Button x:Name="QuarantineCandidateFilterButton"
                            Content="Quarantine candidates"
                            MinWidth="150"
                            Click="QuarantineCandidateFilterButton_Click" />
                    <Button x:Name="AccessIssuesFilterButton"
                            Content="Access issues"
                            MinWidth="125"
                            Click="AccessIssuesFilterButton_Click" />
                    <Button x:Name="ExportCsvButton"
                            Content="Export CSV"
                            MinWidth="110"
                            IsEnabled="False"
                            Click="ExportCsvButton_Click" />
                </WrapPanel>

                <TextBlock x:Name="FilterSummaryText"
                           Foreground="#526171"
                           Margin="6,8,0,6"
                           Text="No scan loaded"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="ReviewSizeNoteText"
                           Foreground="#526171"
                           Margin="6,0,0,8"
                           Text="Folder sizes include child files; parent and child rows can overlap. Treat row sizes as triage clues, not storage savings."
                           TextWrapping="Wrap" />

                <WrapPanel x:Name="ReviewActionToolbar">
                    <StackPanel Orientation="Horizontal"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="Search"
                                   VerticalAlignment="Center"
                                   Foreground="#526171"
                                   Margin="0,0,8,0" />
                        <TextBox x:Name="SearchBox"
                                 Width="220"
                                 Height="30"
                                 VerticalContentAlignment="Center"
                                 IsEnabled="False"
                                 ToolTip="Examples: pip, path:pip, parent:C:\Users\moxhe\AppData, category:Python package cache, rating:High risk, recommendation:Quarantine candidate, access:readable, access:access issue, issue:denied"
                                 TextChanged="SearchBox_TextChanged" />
                    </StackPanel>
                    <Button x:Name="ClearSearchButton"
                            Content="Clear search"
                            MinWidth="110"
                            IsEnabled="False"
                            Click="ClearSearchButton_Click" />
                    <Button x:Name="ResetViewButton"
                            Content="Reset view"
                            MinWidth="100"
                            IsEnabled="False"
                            Click="ResetViewButton_Click" />
                    <Button x:Name="PreviousReviewWindowButton"
                            Content="Previous rows"
                            MinWidth="125"
                            IsEnabled="False"
                            Click="PreviousReviewWindowButton_Click" />
                    <TextBlock x:Name="ReviewWindowText"
                               Text="Rows appear after a scan."
                               Foreground="#526171"
                               Margin="12,0,6,0"
                               VerticalAlignment="Center" />
                    <Button x:Name="NextReviewWindowButton"
                            Content="Next rows"
                            MinWidth="105"
                            IsEnabled="False"
                            Click="NextReviewWindowButton_Click" />
                    <StackPanel Orientation="Horizontal"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="Type"
                                   VerticalAlignment="Center"
                                   Foreground="#526171"
                                   Margin="0,0,8,0" />
                        <ComboBox x:Name="EntryTypeFilterBox"
                                  Width="135"
                                  Height="30"
                                  DisplayMemberPath="Label"
                                  IsEnabled="False"
                                  SelectionChanged="EntryTypeFilterBox_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="Size"
                                   VerticalAlignment="Center"
                                   Foreground="#526171"
                                   Margin="0,0,8,0" />
                        <ComboBox x:Name="SizeThresholdFilterBox"
                                  Width="135"
                                  Height="30"
                                  DisplayMemberPath="Label"
                                  IsEnabled="False"
                                  SelectionChanged="SizeThresholdFilterBox_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="Category"
                                   VerticalAlignment="Center"
                                   Foreground="#526171"
                                   Margin="0,0,8,0" />
                        <ComboBox x:Name="CategoryFilterBox"
                                  Width="290"
                                  Height="30"
                                  DisplayMemberPath="Label"
                                  IsEnabled="False"
                                  SelectionChanged="CategoryFilterBox_SelectionChanged" />
                    </StackPanel>
                </WrapPanel>

                <WrapPanel x:Name="ReviewShortlistToolbar"
                           Margin="0,6,0,0">
                    <Button x:Name="AddShownToShortlistButton"
                            Content="Shortlist shown"
                            MinWidth="125"
                            IsEnabled="False"
                            Click="AddShownToShortlistButton_Click" />
                    <Button x:Name="RemoveShownFromShortlistButton"
                            Content="Remove shown"
                            MinWidth="115"
                            IsEnabled="False"
                            Click="RemoveShownFromShortlistButton_Click" />
                    <Button x:Name="ExportShortlistCsvButton"
                            Content="Export shortlist"
                            MinWidth="125"
                            IsEnabled="False"
                            Click="ExportShortlistCsvButton_Click" />
                    <Button x:Name="ClearShortlistButton"
                            Content="Clear shortlist"
                            MinWidth="120"
                            IsEnabled="False"
                            Click="ClearShortlistButton_Click" />
                    <Button x:Name="PreviewQuarantineButton"
                            Content="Preview quarantine"
                            MinWidth="145"
                            IsEnabled="False"
                            Click="PreviewQuarantineButton_Click" />
                    <StackPanel Margin="6,0,0,0"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Quarantine root"
                                       VerticalAlignment="Center"
                                       Foreground="#526171"
                                       Margin="0,0,8,0" />
                            <TextBox x:Name="QuarantineRootBox"
                                     Width="260"
                                     Height="30"
                                     VerticalContentAlignment="Center"
                                     Text="D:\WindowsFileCleanerQuarantine"
                                     ToolTip="Read-only preview destination root. Preview does not create this folder or move files."
                                     TextChanged="QuarantineRootBox_TextChanged" />
                            <Button x:Name="BrowseQuarantineRootButton"
                                    Content="Browse..."
                                    MinWidth="100"
                                    Click="BrowseQuarantineRootButton_Click" />
                        </StackPanel>
                        <TextBlock x:Name="QuarantineRootSafetyNoteText"
                                   Width="520"
                                   Foreground="#526171"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Button x:Name="ExportQuarantinePreviewButton"
                            Content="Export preview"
                            MinWidth="120"
                            IsEnabled="False"
                            Click="ExportQuarantinePreviewButton_Click" />
                </WrapPanel>
            </StackPanel>

            <DataGrid x:Name="ResultsGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      SelectionChanged="ResultsGrid_SelectionChanged"
                      Background="White"
                      BorderBrush="#DCE3EA"
                      HorizontalGridLinesBrush="#E8EEF4"
                      RowHeight="24"
                      BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Shortlist" Binding="{Binding Shortlist}" Width="80" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.4*" />
                    <DataGridTextColumn Header="Relative path" Binding="{Binding RelativePath}" Width="1.5*" />
                    <DataGridTextColumn Header="Parent" Binding="{Binding ParentLocation}" Width="1.6*" />
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="90" />
                    <DataGridTextColumn Header="Size" Binding="{Binding Size}" SortMemberPath="SizeBytes" Width="100" />
                    <DataGridTextColumn Header="Contents" Binding="{Binding Contents}" SortMemberPath="ContainedTotalCount" Width="155" />
                    <DataGridTextColumn Header="Importance" Binding="{Binding Importance}" Width="120" />
                    <DataGridTextColumn Header="Recommendation" Binding="{Binding Recommendation}" Width="155" />
                    <DataGridTextColumn Header="Categories" Binding="{Binding Categories}" Width="220" />
                    <DataGridTextColumn Header="Access" Binding="{Binding AccessStatus}" Width="105" />
                    <DataGridTextColumn Header="Modified" Binding="{Binding LastModified}" Width="135" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="2"
                    Grid.Row="1"
                    Background="White"
                    BorderBrush="#DCE3EA"
                    BorderThickness="1"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="DetailTitleText"
                               Text="Select a result"
                               FontSize="18"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="DetailPathText"
                               Grid.Row="1"
                               Text=""
                               Foreground="#526171"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="DetailPathContextText"
                               Grid.Row="2"
                               Text=""
                               Foreground="#526171"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="DetailMetaText"
                               Grid.Row="3"
                               Text=""
                               Margin="0,12,0,0"
                               TextWrapping="Wrap" />
                    <WrapPanel Grid.Row="4"
                               Margin="0,12,0,0">
                        <Button x:Name="AddToShortlistButton"
                                Content="Add to shortlist"
                                MinWidth="130"
                                IsEnabled="False"
                                Click="AddToShortlistButton_Click" />
                        <Button x:Name="RemoveFromShortlistButton"
                                Content="Remove"
                                IsEnabled="False"
                                Click="RemoveFromShortlistButton_Click" />
                        <Button x:Name="CopyPathButton"
                                Content="Copy path"
                                IsEnabled="False"
                                Click="CopyPathButton_Click" />
                        <Button x:Name="ShowChildrenButton"
                                Content="Show children"
                                MinWidth="115"
                                IsEnabled="False"
                                Click="ShowChildrenButton_Click" />
                        <Button x:Name="PreviewFileButton"
                                Content="Preview file"
                                MinWidth="110"
                                IsEnabled="False"
                                Click="PreviewFileButton_Click" />
                        <Button x:Name="OpenInExplorerButton"
                                Content="Open in Explorer"
                                MinWidth="130"
                                IsEnabled="False"
                                Click="OpenInExplorerButton_Click" />
                    </WrapPanel>
                    <ScrollViewer Grid.Row="5" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Evidence"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock x:Name="DetailEvidenceText"
                                       Text=""
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Review guidance"
                                       FontWeight="SemiBold"
                                       Margin="0,18,0,4" />
                            <TextBlock x:Name="DetailGuidanceText"
                                       Text=""
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Largest immediate children"
                                       FontWeight="SemiBold"
                                       Margin="0,18,0,4" />
                            <TextBlock x:Name="DetailChildrenText"
                                       Text=""
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Largest hotspot trail"
                                       FontWeight="SemiBold"
                                       Margin="0,18,0,4" />
                            <TextBlock x:Name="DetailHotspotTrailText"
                                       Text=""
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="File preview"
                                       FontWeight="SemiBold"
                                       Margin="0,18,0,4" />
                            <TextBlock x:Name="FilePreviewText"
                                       Text="Preview appears after selecting a file and using Preview file."
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Quarantine preview and readiness drafts"
                                       FontWeight="SemiBold"
                                       Margin="0,18,0,4" />
                            <TextBlock x:Name="QuarantinePreviewText"
                                       Text="Preview and draft readiness appear after using Preview quarantine."
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Quarantine execution gate"
                                       FontWeight="SemiBold"
                                       Margin="0,18,0,4" />
                            <WrapPanel>
                                <TextBlock Text="Confirmation"
                                           VerticalAlignment="Center"
                                           Foreground="#526171"
                                           Margin="0,0,8,0" />
                                <TextBox x:Name="QuarantineConfirmationBox"
                                         Width="170"
                                         Height="30"
                                         IsEnabled="False"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Fixture-only execution gate. Real-profile execution stays unavailable in this build."
                                         TextChanged="QuarantineConfirmationBox_TextChanged" />
                                <Button x:Name="ExecuteQuarantineButton"
                                        Content="Execute quarantine"
                                        MinWidth="145"
                                        IsEnabled="False"
                                        Click="ExecuteQuarantineButton_Click" />
                                <Button x:Name="UndoQuarantineButton"
                                        Content="Undo fixture quarantine"
                                        MinWidth="170"
                                        IsEnabled="False"
                                        Click="UndoQuarantineButton_Click" />
                            </WrapPanel>
                            <TextBlock x:Name="QuarantineExecutionGateText"
                                       Text="Execution gate appears after using Preview quarantine."
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Quarantine manifest discovery"
                                       FontWeight="SemiBold"
                                       Margin="0,18,0,4" />
                            <WrapPanel>
                                <Button x:Name="DiscoverQuarantineManifestsButton"
                                        Content="Discover manifests"
                                        MinWidth="145"
                                        Click="DiscoverQuarantineManifestsButton_Click" />
                                <Button x:Name="PreviewRestoreReadinessButton"
                                        Content="Preview restore readiness"
                                        MinWidth="185"
                                        Click="PreviewRestoreReadinessButton_Click" />
                            </WrapPanel>
                            <WrapPanel Margin="0,6,0,0">
                                <TextBlock Text="Selected manifest"
                                           VerticalAlignment="Center"
                                           Foreground="#526171"
                                           Margin="0,0,8,0" />
                                <ComboBox x:Name="RestoreManifestSelectionBox"
                                          Width="520"
                                          MinHeight="30"
                                          DisplayMemberPath="Label"
                                          IsEnabled="False"
                                          SelectionChanged="RestoreManifestSelectionBox_SelectionChanged" />
                                <Button x:Name="PreviewSelectedRestoreManifestReadinessButton"
                                        Content="Preview selected readiness"
                                        MinWidth="205"
                                        IsEnabled="False"
                                        Click="PreviewSelectedRestoreManifestReadinessButton_Click" />
                            </WrapPanel>
                            <TextBlock x:Name="QuarantineManifestDiscoveryText"
                                       Text="Read-only manifest discovery appears after using Discover manifests."
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="SelectedRestoreManifestReviewText"
                                       Text="Selected Restore Manifest Review appears after discovery and Preview selected readiness."
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                            <WrapPanel Margin="0,6,0,0">
                                <Button x:Name="PreviewSelectedRestoreGateButton"
                                        Content="Preview selected restore gate"
                                        MinWidth="210"
                                        IsEnabled="False"
                                        Click="PreviewSelectedRestoreGateButton_Click" />
                                <TextBlock Text="Confirmation"
                                           VerticalAlignment="Center"
                                           Foreground="#526171"
                                           Margin="12,0,8,0" />
                                <TextBox x:Name="SelectedRestoreConfirmationBox"
                                         Width="130"
                                         Height="30"
                                         IsEnabled="False"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Read-only selected restore gate. Discovered-manifest restore execution is unavailable in this build."
                                         TextChanged="SelectedRestoreConfirmationBox_TextChanged" />
                                <Button x:Name="ExecuteSelectedRestoreButton"
                                        Content="Restore selected fixture manifest"
                                        MinWidth="215"
                                        IsEnabled="False"
                                        Click="ExecuteSelectedRestoreButton_Click" />
                            </WrapPanel>
                            <TextBlock x:Name="SelectedRestoreExecutionGateText"
                                       Text="Selected Restore Confirmation Draft appears after Preview selected restore gate."
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="RestoreReadinessPreviewText"
                                       Text="Read-only restore readiness appears after using Preview restore readiness."
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <TextBlock x:Name="StatusText"
                   Grid.Row="4"
                   Text="Ready"
                   Foreground="#526171"
                   Margin="0,12,0,0" />
    </Grid>
</Window>
