<Window x:Class="WindowsFileCleaner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Windows File Cleaner"
        Height="760"
        Width="1180"
        MinHeight="640"
        MinWidth="980"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="6,0,0,0" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#16202A" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Storage Scan"
                           FontSize="26"
                           FontWeight="SemiBold" />
                <TextBlock Text="Read-only review of cleanup candidates"
                           Foreground="#526171"
                           Margin="0,3,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBox x:Name="ScopePathBox"
                         Width="420"
                         Height="34"
                         VerticalContentAlignment="Center"
                         Text="C:\Users\moxhe" />
                <Button x:Name="ScanButton"
                        Content="Scan"
                        Click="ScanButton_Click" />
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        IsEnabled="False"
                        Click="CancelButton_Click" />
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1"
                     Columns="4"
                     Margin="0,0,0,12">
            <Border Background="White" BorderBrush="#DCE3EA" BorderThickness="1" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total size" Foreground="#526171" />
                    <TextBlock x:Name="TotalSizeText" Text="-" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#DCE3EA" BorderThickness="1" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Folders" Foreground="#526171" />
                    <TextBlock x:Name="FolderCountText" Text="-" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#DCE3EA" BorderThickness="1" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Files" Foreground="#526171" />
                    <TextBlock x:Name="FileCountText" Text="-" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#DCE3EA" BorderThickness="1" Padding="14">
                <StackPanel>
                    <TextBlock Text="Access issues" Foreground="#526171" />
                    <TextBlock x:Name="AccessIssueCountText" Text="-" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.ColumnSpan="3" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="AllFilterButton"
                        Grid.Column="0"
                        Content="All"
                        Click="AllFilterButton_Click" />
                <Button x:Name="LikelySafeFilterButton"
                        Grid.Column="1"
                        Content="Likely safe"
                        Click="LikelySafeFilterButton_Click" />
                <Button x:Name="CautionFilterButton"
                        Grid.Column="2"
                        Content="Caution"
                        Click="CautionFilterButton_Click" />
                <Button x:Name="HighRiskFilterButton"
                        Grid.Column="3"
                        Content="High risk"
                        Click="HighRiskFilterButton_Click" />
                <Button x:Name="QuarantineCandidateFilterButton"
                        Grid.Column="4"
                        Content="Quarantine candidates"
                        MinWidth="150"
                        Click="QuarantineCandidateFilterButton_Click" />
                <TextBlock x:Name="FilterSummaryText"
                           Grid.Column="5"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="#526171"
                           Text="No scan loaded" />
            </Grid>

            <DataGrid x:Name="ResultsGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      SelectionChanged="ResultsGrid_SelectionChanged"
                      Background="White"
                      BorderBrush="#DCE3EA"
                      HorizontalGridLinesBrush="#E8EEF4"
                      RowHeight="24"
                      BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="90" />
                    <DataGridTextColumn Header="Size" Binding="{Binding Size}" SortMemberPath="SizeBytes" Width="100" />
                    <DataGridTextColumn Header="Importance" Binding="{Binding Importance}" Width="120" />
                    <DataGridTextColumn Header="Recommendation" Binding="{Binding Recommendation}" Width="155" />
                    <DataGridTextColumn Header="Categories" Binding="{Binding Categories}" Width="220" />
                    <DataGridTextColumn Header="Modified" Binding="{Binding LastModified}" Width="135" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="2"
                    Grid.Row="1"
                    Background="White"
                    BorderBrush="#DCE3EA"
                    BorderThickness="1"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="DetailTitleText"
                               Text="Select a result"
                               FontSize="18"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="DetailPathText"
                               Grid.Row="1"
                               Text=""
                               Foreground="#526171"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="DetailMetaText"
                               Grid.Row="2"
                               Text=""
                               Margin="0,12,0,0"
                               TextWrapping="Wrap" />
                    <ScrollViewer Grid.Row="3" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Evidence"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock x:Name="DetailEvidenceText"
                                       Text=""
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Largest immediate children"
                                       FontWeight="SemiBold"
                                       Margin="0,18,0,4" />
                            <TextBlock x:Name="DetailChildrenText"
                                       Text=""
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <TextBlock x:Name="StatusText"
                   Grid.Row="3"
                   Text="Ready"
                   Foreground="#526171"
                   Margin="0,12,0,0" />
    </Grid>
</Window>
