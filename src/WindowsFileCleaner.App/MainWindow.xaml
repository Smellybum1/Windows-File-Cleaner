<Window x:Class="WindowsFileCleaner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Windows File Cleaner"
        Height="760"
        Width="1180"
        MinHeight="640"
        MinWidth="980"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="6,0,0,0" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#16202A" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0"
                        Grid.Column="0">
                <TextBlock Text="Storage Scan"
                           FontSize="26"
                           FontWeight="SemiBold" />
                <TextBlock Text="Read-only review of cleanup candidates"
                           Foreground="#526171"
                           Margin="0,3,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top">
                <TextBox x:Name="ScopePathBox"
                         Width="420"
                         Height="34"
                         VerticalContentAlignment="Center"
                         Text="C:\Users\moxhe"
                         ToolTip="Chooses a Cleanup Scope path only; editing does not start a scan, bypass the real-profile gate, or approve cleanup."
                         AutomationProperties.HelpText="Chooses a Cleanup Scope path only; editing does not start a scan, bypass the real-profile gate, or approve cleanup."
                         TextChanged="ScopePathBox_TextChanged" />
                <Button x:Name="BrowseScopeButton"
                        Content="Browse..."
                        MinWidth="100"
                        ToolTip="Chooses a Cleanup Scope path only; browsing does not start a scan, bypass the real-profile gate, or approve cleanup."
                        AutomationProperties.HelpText="Chooses a Cleanup Scope path only; browsing does not start a scan, bypass the real-profile gate, or approve cleanup."
                        ToolTipService.ShowOnDisabled="True"
                        Click="BrowseScopeButton_Click" />
                <Button x:Name="ScanButton"
                        Content="Scan"
                        ToolTipService.ShowOnDisabled="True"
                        Click="ScanButton_Click" />
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        IsEnabled="False"
                        ToolTip="Requests cancellation of the in-progress read-only Storage Scan; it does not move, delete, quarantine, restore, or approve cleanup."
                        AutomationProperties.HelpText="Requests cancellation of the in-progress read-only Storage Scan; it does not move, delete, quarantine, restore, or approve cleanup."
                        ToolTipService.ShowOnDisabled="True"
                        Click="CancelButton_Click" />
            </StackPanel>

            <WrapPanel x:Name="ScopeStatusPanel"
                       Grid.Row="1"
                       Grid.ColumnSpan="2"
                       Margin="0,6,0,0"
                       HorizontalAlignment="Right">
                <DockPanel Width="640"
                           Margin="0,0,14,0"
                           LastChildFill="True">
                    <Border x:Name="CleanupScopeSafetyNoteHelpCue"
                            DockPanel.Dock="Right"
                            Width="18"
                            Height="18"
                            Margin="8,1,0,0"
                            CornerRadius="9"
                            Background="#F4F7FA"
                            BorderBrush="#8A99A8"
                            BorderThickness="1"
                            VerticalAlignment="Top"
                            Cursor="Help"
                            ToolTipService.InitialShowDelay="250"
                            ToolTip="Cleanup Scope Safety Note appears after a Cleanup Scope is entered. It is read-only scope context; it does not start scanning, run preflight, create fixtures, persist approval, or approve cleanup."
                            AutomationProperties.Name="Cleanup Scope Safety Note help cue"
                            AutomationProperties.HelpText="Cleanup Scope Safety Note appears after a Cleanup Scope is entered. It is read-only scope context; it does not start scanning, run preflight, create fixtures, persist approval, or approve cleanup.">
                        <TextBlock Text="?"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#526171" />
                    </Border>
                    <TextBlock x:Name="ScopeSafetyNoteText"
                               Foreground="#526171"
                               TextWrapping="Wrap"
                               ToolTip="Cleanup Scope Safety Note appears after a Cleanup Scope is entered. It is read-only scope context; it does not start scanning, run preflight, create fixtures, persist approval, or approve cleanup."
                               AutomationProperties.HelpText="Cleanup Scope Safety Note appears after a Cleanup Scope is entered. It is read-only scope context; it does not start scanning, run preflight, create fixtures, persist approval, or approve cleanup." />
                </DockPanel>
                <DockPanel x:Name="ScanGateSummaryPanel"
                           Width="640"
                           Margin="0,0,14,0"
                           LastChildFill="True">
                    <Border x:Name="ScanGateSummaryHelpCue"
                            DockPanel.Dock="Right"
                            Width="18"
                            Height="18"
                            Margin="8,1,0,0"
                            CornerRadius="9"
                            Background="#F4F7FA"
                            BorderBrush="#8A99A8"
                            BorderThickness="1"
                            VerticalAlignment="Top"
                            Cursor="Help"
                            ToolTipService.InitialShowDelay="250"
                            ToolTip="Scan gate status appears after a Cleanup Scope is entered. This scan-gate status is read-only; it does not start scanning by itself, move files, or approve cleanup."
                            AutomationProperties.Name="Scan gate summary help cue"
                            AutomationProperties.HelpText="Scan gate status appears after a Cleanup Scope is entered. This scan-gate status is read-only; it does not start scanning by itself, move files, or approve cleanup.">
                        <TextBlock Text="?"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#526171" />
                    </Border>
                    <TextBlock x:Name="ScanGateSummaryText"
                               FontWeight="SemiBold"
                               Foreground="#9A5B00"
                               TextWrapping="Wrap"
                               ToolTip="Scan gate status appears after a Cleanup Scope is entered. This scan-gate status is read-only; it does not start scanning by itself, move files, or approve cleanup."
                               AutomationProperties.HelpText="Scan gate status appears after a Cleanup Scope is entered. This scan-gate status is read-only; it does not start scanning by itself, move files, or approve cleanup." />
                </DockPanel>
                <TextBlock x:Name="ScanGateText"
                           Width="520"
                           Foreground="#526171"
                           Margin="0,1,0,0"
                           TextWrapping="Wrap" />
            </WrapPanel>

            <DockPanel x:Name="RealProfilePreflightPanel"
                       Grid.Row="2"
                       Grid.ColumnSpan="2"
                       Width="680"
                       Margin="0,6,0,0"
                       HorizontalAlignment="Right"
                       Visibility="Collapsed"
                       LastChildFill="True">
                <Border x:Name="RealProfilePreflightHelpCue"
                        DockPanel.Dock="Right"
                        Width="18"
                        Height="18"
                        Margin="8,1,0,0"
                        CornerRadius="9"
                        Background="#F4F7FA"
                        BorderBrush="#8A99A8"
                        BorderThickness="1"
                        VerticalAlignment="Top"
                        Cursor="Help"
                        ToolTipService.InitialShowDelay="250"
                        ToolTip="Acknowledges that MVP preflight and fixture review were already run before this real-profile Storage Scan; this does not run preflight, create fixtures, start scanning, persist approval, or approve cleanup."
                        AutomationProperties.Name="Real-profile preflight acknowledgement help cue"
                        AutomationProperties.HelpText="Acknowledges that MVP preflight and fixture review were already run before this real-profile Storage Scan; this does not run preflight, create fixtures, start scanning, persist approval, or approve cleanup.">
                    <TextBlock Text="?"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#526171" />
                </Border>
                <CheckBox x:Name="RealProfilePreflightCheckBox"
                          Content="I ran MVP preflight and fixture review before scanning this real profile."
                          ToolTip="Acknowledges that MVP preflight and fixture review were already run before this real-profile Storage Scan; this does not run preflight, create fixtures, start scanning, persist approval, or approve cleanup."
                          AutomationProperties.HelpText="Acknowledges that MVP preflight and fixture review were already run before this real-profile Storage Scan; this does not run preflight, create fixtures, start scanning, persist approval, or approve cleanup."
                          ToolTipService.ShowOnDisabled="True"
                          Checked="RealProfilePreflightCheckBox_Changed"
                          Unchecked="RealProfilePreflightCheckBox_Changed" />
            </DockPanel>
        </Grid>

        <UniformGrid Grid.Row="1"
                     Columns="4"
                     Margin="0,0,0,12">
            <Border Background="White" BorderBrush="#DCE3EA" BorderThickness="1" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total size" Foreground="#526171" />
                    <TextBlock x:Name="TotalSizeText" Text="-" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#DCE3EA" BorderThickness="1" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Folders" Foreground="#526171" />
                    <TextBlock x:Name="FolderCountText" Text="-" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#DCE3EA" BorderThickness="1" Padding="14" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Files" Foreground="#526171" />
                    <TextBlock x:Name="FileCountText" Text="-" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#DCE3EA" BorderThickness="1" Padding="14">
                <StackPanel>
                    <TextBlock Text="Access issues" Foreground="#526171" />
                    <TextBlock x:Name="AccessIssueCountText" Text="-" FontSize="20" FontWeight="SemiBold" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#DCE3EA"
                BorderThickness="1"
                Padding="12"
                Margin="0,0,0,12">
            <Expander x:Name="SafetySummaryExpander"
                      IsExpanded="True">
                <Expander.Header>
                    <DockPanel LastChildFill="True">
                        <Border x:Name="SafetySummaryHeaderHelpCue"
                                DockPanel.Dock="Right"
                                Width="18"
                                Height="18"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Background="#F4F7FA"
                                BorderBrush="#8A99A8"
                                BorderThickness="1"
                                CornerRadius="9"
                                Cursor="Help"
                                ToolTipService.InitialShowDelay="250"
                                ToolTip="Safety Summary: waiting for scan. Header state: neutral. Header summary is read-only review context, not cleanup approval."
                                AutomationProperties.Name="Safety Summary header help cue"
                                AutomationProperties.HelpText="Safety Summary: waiting for scan. Header state: neutral. Header summary is read-only review context, not cleanup approval.">
                            <TextBlock Text="?"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#526171" />
                        </Border>
                        <TextBlock x:Name="SafetySummaryHeaderText"
                                   Text="Safety Summary: waiting for scan"
                                   FontWeight="SemiBold"
                                   Foreground="#526171"
                                   Tag="Neutral"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="Safety Summary: waiting for scan. Header state: neutral. Header summary is read-only review context, not cleanup approval."
                                   AutomationProperties.HelpText="Safety Summary: waiting for scan. Header state: neutral. Header summary is read-only review context, not cleanup approval." />
                    </DockPanel>
                </Expander.Header>
                <StackPanel Margin="0,6,0,0">
                    <DockPanel LastChildFill="True">
                        <Border x:Name="ReviewMixHelpCue"
                                DockPanel.Dock="Right"
                                Width="18"
                                Height="18"
                                Margin="8,1,0,0"
                                CornerRadius="9"
                                Background="#F4F7FA"
                                BorderBrush="#8A99A8"
                                BorderThickness="1"
                                VerticalAlignment="Top"
                                Cursor="Help"
                                ToolTipService.InitialShowDelay="250"
                                ToolTip="Review mix appears after a scan. Review Mix is read-only whole-scan review context; it does not rescan, modify files, prove storage savings, or approve cleanup. Largest rows are triage clues because recursive parent and child rows can overlap."
                                AutomationProperties.Name="Review Mix help cue"
                                AutomationProperties.HelpText="Review mix appears after a scan. Review Mix is read-only whole-scan review context; it does not rescan, modify files, prove storage savings, or approve cleanup. Largest rows are triage clues because recursive parent and child rows can overlap.">
                            <TextBlock Text="?"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#526171" />
                        </Border>
                        <TextBlock x:Name="ReviewMixText"
                                   Text="Review mix appears after a scan."
                                   Foreground="#526171"
                                   TextWrapping="Wrap"
                                   ToolTip="Review mix appears after a scan. Review Mix is read-only whole-scan review context; it does not rescan, modify files, prove storage savings, or approve cleanup. Largest rows are triage clues because recursive parent and child rows can overlap."
                                   AutomationProperties.HelpText="Review mix appears after a scan. Review Mix is read-only whole-scan review context; it does not rescan, modify files, prove storage savings, or approve cleanup. Largest rows are triage clues because recursive parent and child rows can overlap." />
                    </DockPanel>
                    <TextBlock x:Name="SafetySummaryText"
                               Text="Safety summary appears after a scan."
                               Foreground="#526171"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                    <WrapPanel Margin="0,8,0,0">
                        <Button x:Name="SafetyHighRiskButton"
                                Content="Review high risk"
                                MinWidth="125"
                                IsEnabled="False"
                                ToolTip="Applies a read-only review shortcut to High risk rows from the completed Storage Scan; this does not rescan, modify files, or approve cleanup."
                                AutomationProperties.HelpText="Applies a read-only review shortcut to High risk rows from the completed Storage Scan; this does not rescan, modify files, or approve cleanup."
                                ToolTipService.ShowOnDisabled="True"
                                Click="SafetyHighRiskButton_Click" />
                        <Button x:Name="SafetyProtectedButton"
                                Content="Review protected"
                                MinWidth="135"
                                IsEnabled="False"
                                ToolTip="Applies a read-only review shortcut to Protected Location rows; this does not rescan, modify files, or approve cleanup."
                                AutomationProperties.HelpText="Applies a read-only review shortcut to Protected Location rows; this does not rescan, modify files, or approve cleanup."
                                ToolTipService.ShowOnDisabled="True"
                                Click="SafetyProtectedButton_Click" />
                        <Button x:Name="SafetyAccessIssuesButton"
                                Content="Review access"
                                MinWidth="120"
                                IsEnabled="False"
                                ToolTip="Applies a read-only review shortcut to Access issue rows; this does not retry, elevate, change permissions, modify files, or approve cleanup."
                                AutomationProperties.HelpText="Applies a read-only review shortcut to Access issue rows; this does not retry, elevate, change permissions, modify files, or approve cleanup."
                                ToolTipService.ShowOnDisabled="True"
                                Click="SafetyAccessIssuesButton_Click" />
                        <Button x:Name="SafetyReparsePointsButton"
                                Content="Review reparse"
                                MinWidth="125"
                                IsEnabled="False"
                                ToolTip="Applies a read-only review shortcut to reparse point rows; this does not follow links, rescan, modify files, or approve cleanup."
                                AutomationProperties.HelpText="Applies a read-only review shortcut to reparse point rows; this does not follow links, rescan, modify files, or approve cleanup."
                                ToolTipService.ShowOnDisabled="True"
                                Click="SafetyReparsePointsButton_Click" />
                        <Button x:Name="SafetyQuarantineCandidatesButton"
                                Content="Review quarantine"
                                MinWidth="145"
                                IsEnabled="False"
                                ToolTip="Applies a read-only review shortcut to Quarantine candidate rows; this is not Quarantine approval and no files are modified."
                                AutomationProperties.HelpText="Applies a read-only review shortcut to Quarantine candidate rows; this is not Quarantine approval and no files are modified."
                                ToolTipService.ShowOnDisabled="True"
                                Click="SafetyQuarantineCandidatesButton_Click" />
                        <Button x:Name="SafetyNoCategoryButton"
                                Content="Review no category"
                                MinWidth="145"
                                IsEnabled="False"
                                ToolTip="Applies a read-only review shortcut to No category rows that need classification; this does not rescan, modify files, or approve cleanup."
                                AutomationProperties.HelpText="Applies a read-only review shortcut to No category rows that need classification; this does not rescan, modify files, or approve cleanup."
                                ToolTipService.ShowOnDisabled="True"
                                Click="SafetyNoCategoryButton_Click" />
                    </WrapPanel>
                </StackPanel>
            </Expander>
        </Border>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.ColumnSpan="3" Margin="0,0,0,10">
                <WrapPanel x:Name="ReviewFilterToolbar">
                    <Button x:Name="AllFilterButton"
                            Content="All"
                            ToolTip="Shows all completed Storage Scan review rows in the active review lens; this does not rescan, modify files, or approve cleanup."
                            AutomationProperties.HelpText="Shows all completed Storage Scan review rows in the active review lens; this does not rescan, modify files, or approve cleanup."
                            Click="AllFilterButton_Click" />
                    <Button x:Name="LikelySafeFilterButton"
                            Content="Likely safe"
                            ToolTip="Shows rows rated Likely safe for review only; rating is not cleanup approval and no files are modified."
                            AutomationProperties.HelpText="Shows rows rated Likely safe for review only; rating is not cleanup approval and no files are modified."
                            Click="LikelySafeFilterButton_Click" />
                    <Button x:Name="CautionFilterButton"
                            Content="Caution"
                            ToolTip="Shows rows rated Caution for inspection; this does not rescan, modify files, or approve cleanup."
                            AutomationProperties.HelpText="Shows rows rated Caution for inspection; this does not rescan, modify files, or approve cleanup."
                            Click="CautionFilterButton_Click" />
                    <Button x:Name="HighRiskFilterButton"
                            Content="High risk"
                            ToolTip="Shows rows rated High risk for inspection first; this does not rescan, modify files, or approve cleanup."
                            AutomationProperties.HelpText="Shows rows rated High risk for inspection first; this does not rescan, modify files, or approve cleanup."
                            Click="HighRiskFilterButton_Click" />
                    <Button x:Name="QuarantineCandidateFilterButton"
                            Content="Quarantine candidates"
                            MinWidth="150"
                            ToolTip="Shows rows recommended as Quarantine candidates for review only; this is not Quarantine approval and no files are modified."
                            AutomationProperties.HelpText="Shows rows recommended as Quarantine candidates for review only; this is not Quarantine approval and no files are modified."
                            Click="QuarantineCandidateFilterButton_Click" />
                    <Button x:Name="AccessIssuesFilterButton"
                            Content="Access issues"
                            MinWidth="125"
                            ToolTip="Shows rows with scan Access issues for review only; this does not retry, elevate, change permissions, modify files, or approve cleanup."
                            AutomationProperties.HelpText="Shows rows with scan Access issues for review only; this does not retry, elevate, change permissions, modify files, or approve cleanup."
                            Click="AccessIssuesFilterButton_Click" />
                    <Button x:Name="ExportCsvButton"
                            Content="Export CSV"
                            MinWidth="110"
                            IsEnabled="False"
                            ToolTip="Exports the current active review lens as a CSV report; this is not cleanup approval and no scanned files are modified."
                            AutomationProperties.HelpText="Exports the current active review lens as a CSV report; this is not cleanup approval and no scanned files are modified."
                            ToolTipService.ShowOnDisabled="True"
                            Click="ExportCsvButton_Click" />
                </WrapPanel>

                <TextBlock x:Name="FilterSummaryText"
                           Foreground="#526171"
                           Margin="6,8,0,6"
                           Text="No scan loaded"
                           TextWrapping="Wrap" />
                <DockPanel Margin="6,0,0,6"
                           LastChildFill="True">
                    <Border x:Name="MatchedReviewMixHelpCue"
                            DockPanel.Dock="Right"
                            Width="18"
                            Height="18"
                            Margin="8,1,0,0"
                            CornerRadius="9"
                            Background="#F4F7FA"
                            BorderBrush="#8A99A8"
                            BorderThickness="1"
                            VerticalAlignment="Top"
                            Cursor="Help"
                            ToolTipService.InitialShowDelay="250"
                            ToolTip="Matched review mix appears after a scan. Matched Review Mix is read-only active-review-lens context; it does not rescan, modify files, prove storage savings, or approve cleanup. Counts cover all matched rows, not only the visible display window."
                            AutomationProperties.Name="Matched Review Mix help cue"
                            AutomationProperties.HelpText="Matched review mix appears after a scan. Matched Review Mix is read-only active-review-lens context; it does not rescan, modify files, prove storage savings, or approve cleanup. Counts cover all matched rows, not only the visible display window.">
                        <TextBlock Text="?"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#526171" />
                    </Border>
                    <TextBlock x:Name="MatchedReviewMixText"
                               Foreground="#526171"
                               Text="Matched review mix appears after a scan."
                               TextWrapping="Wrap"
                               ToolTip="Matched review mix appears after a scan. Matched Review Mix is read-only active-review-lens context; it does not rescan, modify files, prove storage savings, or approve cleanup. Counts cover all matched rows, not only the visible display window."
                               AutomationProperties.HelpText="Matched review mix appears after a scan. Matched Review Mix is read-only active-review-lens context; it does not rescan, modify files, prove storage savings, or approve cleanup. Counts cover all matched rows, not only the visible display window." />
                </DockPanel>
                <TextBlock x:Name="ReviewSizeNoteText"
                           Foreground="#526171"
                           Margin="6,0,0,8"
                           Text="Folder sizes include child files; parent and child rows can overlap. Treat row sizes as triage clues, not storage savings."
                           TextWrapping="Wrap" />

                <WrapPanel x:Name="ReviewActionToolbar">
                    <StackPanel Orientation="Horizontal"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="Search"
                                   VerticalAlignment="Center"
                                   Foreground="#526171"
                                   Margin="0,0,8,0" />
                        <TextBox x:Name="SearchBox"
                                 Width="220"
                                 Height="30"
                                 VerticalContentAlignment="Center"
                                 IsEnabled="False"
                                 ToolTip="Examples: pip, path:pip, parent:C:\Users\moxhe\AppData, under:C:\Users\moxhe\AppData, category:Python package cache, rating:High risk, recommendation:Quarantine candidate, access:readable, access:access issue, issue:denied"
                                 AutomationProperties.HelpText="Searches completed Storage Scan review rows after a short pause. Examples: pip, path:pip, parent:C:\Users\moxhe\AppData, under:C:\Users\moxhe\AppData, category:Python package cache, rating:High risk, recommendation:Quarantine candidate, access:readable, access:access issue, issue:denied. Search is read-only and does not rescan, modify files, or approve cleanup."
                                 TextChanged="SearchBox_TextChanged" />
                    </StackPanel>
                    <Button x:Name="ClearSearchButton"
                            Content="Clear search"
                            MinWidth="110"
                            IsEnabled="False"
                            ToolTip="Clears only Storage Review Search for the completed scan; this does not rescan, modify files, or clear Review Shortlist."
                            AutomationProperties.HelpText="Clears only Storage Review Search for the completed scan; this does not rescan, modify files, or clear Review Shortlist."
                            ToolTipService.ShowOnDisabled="True"
                            Click="ClearSearchButton_Click" />
                    <Button x:Name="ResetViewButton"
                            Content="Reset view"
                            MinWidth="100"
                            IsEnabled="False"
                            ToolTip="Clears active review filters and search while keeping Review Shortlist; this does not rescan or modify files."
                            AutomationProperties.HelpText="Clears active review filters and search while keeping Review Shortlist; this does not rescan or modify files."
                            ToolTipService.ShowOnDisabled="True"
                            Click="ResetViewButton_Click" />
                    <Button x:Name="PreviousReviewWindowButton"
                            Content="Previous rows"
                            MinWidth="125"
                            IsEnabled="False"
                            ToolTip="Moves to the previous in-memory Storage Review Display Window; this does not rescan or modify files."
                            AutomationProperties.HelpText="Moves to the previous in-memory Storage Review Display Window; this does not rescan or modify files."
                            ToolTipService.ShowOnDisabled="True"
                            Click="PreviousReviewWindowButton_Click" />
                    <TextBlock x:Name="ReviewWindowText"
                               Text="Rows appear after a scan."
                               Foreground="#526171"
                               Margin="12,0,6,0"
                               VerticalAlignment="Center" />
                    <Button x:Name="NextReviewWindowButton"
                            Content="Next rows"
                            MinWidth="105"
                            IsEnabled="False"
                            ToolTip="Moves to the next in-memory Storage Review Display Window; this does not rescan or modify files."
                            AutomationProperties.HelpText="Moves to the next in-memory Storage Review Display Window; this does not rescan or modify files."
                            ToolTipService.ShowOnDisabled="True"
                            Click="NextReviewWindowButton_Click" />
                    <StackPanel Orientation="Horizontal"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="Type"
                                   VerticalAlignment="Center"
                                   Foreground="#526171"
